---
 klippy/extras/display/menu.cfg | 8 ++++++--
 klippy/klippy.py               | 3 ++-
 2 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/klippy/extras/display/menu.cfg b/klippy/extras/display/menu.cfg
index dc12b65..3567455 100755
--- a/klippy/extras/display/menu.cfg
+++ b/klippy/extras/display/menu.cfg
@@ -35,6 +35,8 @@ name: Calibration
 gcode: 
     M117 Eddy Calibrate
     G28
+    G90
+    G1 Z15
     Z_OFFSET_CALIBRATION METHOD=force_overlay
     M117 Input Shaping
     SHAPER_CALIBRATE
@@ -637,6 +639,8 @@ name: Eddy Calibrate
 gcode: 
     M117 Eddy Calibrate
     G28
+    G90
+    G1 Z15
     Z_OFFSET_CALIBRATION METHOD=force_overlay
     SAVE_VARIABLE VARIABLE=factory_reset VALUE=True
     SAVE_CONFIG
@@ -733,12 +737,12 @@ name: Information
 
 [menu __main __info __version]
 type: command
-name: 1.3.5
+name: 1.3.6
 gcode:
 
 [menu __main __info __time]
 type: command
-name: 2025-1-15
+name: 2025-1-17
 gcode:
 
 [menu __main __info __factory]
diff --git a/klippy/klippy.py b/klippy/klippy.py
index d369e46..6257c89 100644
--- a/klippy/klippy.py
+++ b/klippy/klippy.py
@@ -211,7 +211,8 @@ class Printer:
         
         for index, theMsg in enumerate(["Lost communication with MCU", "Shutdown due to webhooks request", "ADC out of range", "Heater extruder not heating at expected rate",
                                       "Heater heater_bed not heating at expected rate", "TMC 'stepper_x' reports error", "TMC 'stepper_y' reports error",
-                                      "TMC 'stepper_z' reports error", "TMC 'extruder' reports error", "Move queue overflow", "Missed scheduling of next digital out event"]):
+                                      "TMC 'stepper_z' reports error", "TMC 'extruder' reports error", "Move queue overflow", "Missed scheduling of next digital out event",
+                                      "Unable to write tmc spi 'stepper_x' register", "Unable to write tmc spi 'stepper_y' register"]):
             if theMsg in msg or theMsg in mcu_msg:
                 self.shutCode = 60 + index
          
-- 
